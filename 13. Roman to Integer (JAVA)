class Solution {

    public int val(char ch) {
        switch(ch) {
            case 'I' : return 1;
            case 'V' : return 5;
            case 'X' : return 10;
            case 'L' : return 50;
            case 'C' : return 100;
            case 'D' : return 500;
            case 'M' : return 1000;
            default: return 0;
        }
    }
    public int romanToInt(String s) {
        int num = 0;

        for (int i = 0; i < s.length(); i++) {
            int current = val(s.charAt(i));
            if(i < s.length() - 1 && current < val(s.charAt(i+1))) {
                num -= current;
            } else{
                num += current;
            }
        }
        
        return num;
    }
}
