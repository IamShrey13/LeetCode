class Solution:
    def romanToInt(self, s: str) -> int:
        i_val = {"I":1, "V":5, "X":10, "L":50, "C":100, "D":500, "M":1000}
        num = 0
        for i in range(len(s)):
            if i < len(s) - 1 and i_val[s[i]] < i_val[s[i+1]]:
                num -= i_val[s[i]]
            else:
                num += i_val[s[i]]
        return num
        
