class Solution:
    def isPalindrome(self, x: int) -> bool:
        if (x < 0):
            return False
        nv = 0
        cx = x
        while(cx != 0):
            nv = nv*10 + cx%10
            cx = cx // 10
        if (nv == x):
            return True
        else:
            return False
        
